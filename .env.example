# =============================================
# POH Backend Environment Configuration
# Copy this file to .env and adjust for your VPS
# =============================================

# --- Server ---
NODE_ENV=production
PORT=3000

# --- QVAC (Primary - recommended for your 8CPU / 32GB VPS, no GPU) ---
# Run QVAC with: qvac serve openai --port 11435
QVAC_URL=http://localhost:11435

# Fast model (used for 90%+ of brain calls) - excellent on your hardware
EVALUATOR_FAST_MODEL=qwen2.5:14b

# Heavy model (escalates for low confidence / sanctions) 
# 32B Q4_K_M uses ~20-22GB RAM - monitor with htop. If OOM, switch to 14B or 27B.
EVALUATOR_HEAVY_MODEL=qwen2.5:32b

# Other brain roles - use same efficient models
LEARNER_MODEL=qwen2.5:14b
COMPILER_MODEL=qwen2.5:14b   # Used for consolidation - keep light

QVAC_MODEL=qwen2.5:14b   # Default for QVAC calls

# Fallback (only if QVAC_URL is empty)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# --- Blockchain RPCs ---
SOLANA_RPC=https://api.mainnet-beta.solana.com
RPC_56=https://bnb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE   # For BNB chain tx graph

# Etherscan (for EVM transaction graph)
ETHERSCAN_API_KEY=your_etherscan_key_here

# --- Payments & Fees ---
FEE_RECIPIENT=PUT_YOUR_FEE_WALLET_ADDRESS_HERE
POH_MINT=your_poh_token_mint_address

# --- Other ---
# SOLANA_RPC for tx graph on Solana
# Add any other secrets as needed